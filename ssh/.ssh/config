# Default github.com → work identity.
# Catches `git@github.com:org/repo` remotes in repos that don't fall under
# an identity-specific includeIf (e.g. ad-hoc clones).
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/workgithub_id_ed25519.pub
    IdentitiesOnly yes

# Aliases used by `url."git@github.com-{work,personal}:".insteadOf` in the
# per-identity gitconfigs. Each alias pins ssh to one .pub file as a selector,
# so the 1Password agent presents only the matching private key.
Host github.com-work
    HostName github.com
    User git
    IdentityFile ~/.ssh/workgithub_id_ed25519.pub
    IdentitiesOnly yes

Host github.com-personal
    HostName github.com
    User git
    IdentityFile ~/.ssh/mitchesgotglitches_id_ed25519.pub
    IdentitiesOnly yes
